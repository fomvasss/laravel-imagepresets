{
    "name": "fomvasss/laravel-imagepresets",
    "description": "Image presets (on-the-fly resize/convert) for Laravel via League Glide",
    "keywords": [
        "laravel",
        "image",
        "preset",
        "resize",
        "glide",
        "webp",
        "fomvasss"
    ],
    "authors": [
        {
            "name": "Vasyl Fomin",
            "email": "fomvasss@gmail.com",
            "role": "Developer"
        }
    ],
    "license": "MIT",
    "funding": [
        {
            "type": "custom",
            "url": "https://send.monobank.ua/jar/5xsqtHvVrY"
        },
        {
            "type": "ko_fi",
            "url": "https://ko-fi.com/fomvasss"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "league/glide": "^2.0|^3.0"
    },
    "suggest": {
        "enshrined/svg-sanitize": "Full SVG sanitization (XSS protection). Without this package a basic regex sanitizer is applied."
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Fomvasss\\Imagepresets\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Fomvasss\\Imagepresets\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fomvasss\\Imagepresets\\ImagepresetServiceProvider"
            ],
            "aliases": {
                "Imagepreset": "Fomvasss\\Imagepresets\\Facades\\Imagepreset"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
